---
import Base from '../layouts/Base.astro';
import QuoteForm from '../components/QuoteForm.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import { site, waLink, defaultWaMessage } from '../data/site';
import { testimonials } from '../data/testimonials';

const contactTestimonials = testimonials.slice(1, 3);
---

<Base
  title="צור קשר — קייטרינג שפע טל | הצעת מחיר לאירוע בירושלים"
  description="דברו עם טלי: וואטסאפ, טלפון או טופס קצר — ותקבלו הצעת מחיר לאירוע שלכם עד יום עסקים אחד. קייטרינג ביתי בירושלים."
>
  <section class="section">
    <div class="container contact-grid">
      <div>
        <p class="eyebrow">צור קשר</p>
        <h1>נדבר על השמחה שלכם?</h1>
        <p class="lead">{site.replyPromise}.</p>

        <ul class="contact-list">
          <li>
            <strong>וואטסאפ:</strong>
            <a href={waLink(defaultWaMessage)} target="_blank" rel="noopener">שלחו הודעה עכשיו</a>
          </li>
          <li>
            <strong>טלפון:</strong>
            <a href={`tel:+${site.phoneIntl}`}>{site.phoneDisplay}</a>
          </li>
          <li>
            <strong>מייל:</strong>
            <a href={`mailto:${site.email}`}>{site.email}</a>
          </li>
          <li>
            <strong>כתובת:</strong>
            {site.address} · <a href={site.wazeUrl} target="_blank" rel="noopener">ניווט ב-Waze</a>
          </li>
          <li>
            <strong>פייסבוק:</strong>
            <a href={site.facebookUrl} target="_blank" rel="noopener">קייטרינג שפע טל</a>
          </li>
          <li>
            <strong>כשרות:</strong>
            {site.kashrut}
          </li>
        </ul>

        <div class="contact-quotes">
          {contactTestimonials.map((t) => <TestimonialCard t={t} />)}
        </div>
      </div>

      <div>
        <QuoteForm />
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  @media (max-width: 820px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  .contact-list {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .contact-quotes {
    display: grid;
    gap: 1.25rem;
  }
</style>
