---
import type { Menu } from '../data/menus';
import Motif from './Motif.astro';

interface Props {
  menu: Menu;
  preview?: boolean; /* true: compact card linking to the menus page */
}
const { menu, preview = false } = Astro.props;
const previewItems = menu.sections.flatMap((s) => s.items).slice(0, 4);
---

<article class="menu-card">
  <div class="menu-arch">
    <Motif name={menu.motif} class="menu-motif" />
  </div>
  <div class="menu-body">
    <h3>{menu.title}</h3>
    <p class="motto">{menu.motto}</p>

    {
      preview ? (
        <>
          <ul class="menu-items">
            {previewItems.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a class="menu-link" href={`/menus#${menu.id}`}>
            לתפריט המלא ←
          </a>
        </>
      ) : (
        <>
          <p class="intro">{menu.intro}</p>
          {menu.sections.map((section) => (
            <section>
              <h4>{section.title}</h4>
              <ul class="menu-items">
                {section.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </section>
          ))}
        </>
      )
    }
  </div>
</article>

<style>
  .menu-card {
    background: var(--paper);
    border-radius: 160px 160px 18px 18px;
    box-shadow: var(--shadow-card);
    padding: 2.5rem 1.75rem 1.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .menu-arch {
    display: grid;
    place-items: center;
    width: 86px;
    height: 86px;
    border-radius: 50%;
    background: var(--stone-100);
    color: var(--pom-600);
    margin-bottom: 1.25rem;
  }

  :global(.menu-motif) {
    width: 46px;
    height: 46px;
  }

  .menu-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  h3 {
    margin-bottom: 0.15em;
  }

  .motto {
    color: var(--pom-600);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .intro {
    color: var(--ink-soft);
    max-width: 38ch;
  }

  h4 {
    margin: 1.25rem 0 0.4rem;
    font-size: 0.92rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    color: var(--blue-700);
  }

  .menu-items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    width: 100%;
  }

  .menu-items li {
    padding-bottom: 0.4rem;
    border-bottom: 1px dashed var(--stone-200);
  }

  .menu-items li:last-child {
    border-bottom: none;
  }

  .menu-link {
    margin-top: 1.25rem;
    font-weight: 700;
    color: var(--pom-600);
    text-decoration: none;
  }

  .menu-link:hover {
    color: var(--pom-700);
    text-decoration: underline;
  }
</style>
