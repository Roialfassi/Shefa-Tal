---
import type { Testimonial } from '../data/testimonials';

interface Props {
  t: Testimonial;
}
const { t } = Astro.props;
---

<blockquote class="testimonial">
  <p class="quote">{t.quote}</p>
  <footer>
    <cite>{t.name}</cite>
    <span class="meta">{t.place}{t.event ? ` · ${t.event}` : ''}</span>
  </footer>
</blockquote>

<style>
  .testimonial {
    margin: 0;
    background: var(--paper);
    border-radius: 18px;
    box-shadow: var(--shadow-card);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-top: 4px solid var(--pom-600);
  }

  .quote {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.55;
    flex: 1;
  }

  .quote::before {
    content: '״';
    color: var(--pom-600);
    font-family: var(--font-display);
    font-size: 1.4em;
    line-height: 0;
    margin-inline-end: 0.15em;
  }

  footer {
    display: flex;
    flex-direction: column;
  }

  cite {
    font-style: normal;
    font-weight: 700;
  }

  .meta {
    color: var(--ink-soft);
    font-size: 0.88rem;
  }
</style>
