---
import '@fontsource/suez-one';
import '@fontsource-variable/assistant';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFab from '../components/WhatsAppFab.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description: string;
  lang?: 'he' | 'en';
}
const { title, description, lang = 'he' } = Astro.props;
const dir = lang === 'he' ? 'rtl' : 'ltr';
const canonical = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FoodEstablishment',
  name: site.name,
  alternateName: site.nameEn,
  description:
    lang === 'he'
      ? 'קייטרינג ביתי בירושלים לבריתות, בר ובת מצווה ואירועים בכותל — מהמטבח הביתי של טלי, בצמוד לעיר העתיקה.'
      : 'Home-kitchen kosher catering in Jerusalem for britot, bar and bat mitzvahs and Western Wall events.',
  servesCuisine: 'Kosher',
  telephone: `+${site.phoneIntl}`,
  url: Astro.site?.toString(),
  sameAs: [site.facebookUrl],
  address: {
    '@type': 'PostalAddress',
    streetAddress: "HaNevi'im 8",
    addressLocality: 'Jerusalem',
    addressCountry: 'IL',
  },
  areaServed: 'Jerusalem',
};
---

<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'he' ? 'he_IL' : 'en_US'} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <Header lang={lang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <WhatsAppFab lang={lang} />
  </body>
</html>

<style>
  html,
  body {
    min-height: 100%;
  }

  body {
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }
</style>
